{
  "name": "@bit/client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "start": "bun run server.ts",
    "lint": "oxlint --type-aware --type-check && npm run lint:no-double-assertion && npm run lint:css-vars",
    "lint:css-vars": "node scripts/lint-css-vars.mjs",
    "lint:no-double-assertion": "sh -c 'if rg -n --glob \"*.{ts,tsx}\" --glob \"!**/routeTree.gen.ts\" \"as\\\\s+unknown\\\\s+as\" .; then echo \"Forbidden double assertion: as unknown as\"; exit 1; fi'",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "instant:push:schema": "INSTANT_SCHEMA_FILE_PATH=src/instant.schema.ts bunx instant-cli push schema --yes",
    "instant:push:perms": "cp src/instant.perms.ts instant.perms.ts && bunx instant-cli push perms --yes && rm instant.perms.ts",
    "instant:push": "bun run instant:push:schema && bun run instant:push:perms",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:visual": "vitest run --config vitest.visual.config.ts",
    "test:visual:update": "vitest run --config vitest.visual.config.ts --update"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@cerebras/cerebras_cloud_sdk": "^1.64.1",
    "@instantdb/admin": "^0.22.151",
    "@instantdb/react": "^0.22.151",
    "@octokit/webhooks-types": "^7.6.1",
    "@pierre/diffs": "^1.0.11",
    "@primer/octicons-react": "^19.22.0",
    "@shikijs/markdown-it": "^4.0.1",
    "@tanstack/react-devtools": "^0.9.7",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.163.3",
    "@tanstack/react-router-devtools": "^1.163.3",
    "@tanstack/react-router-ssr-query": "^1.163.3",
    "@tanstack/react-start": "^1.166.1",
    "jose": "^6.1.3",
    "markdown-it-async": "^2.2.0",
    "markdown-it-task-lists": "^2.1.1",
    "motion": "^12.35.0",
    "octokit": "^5.0.5",
    "oxfmt": "^0.36.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shiki": "^4.0.1",
    "vite-tsconfig-paths": "^6.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@hono/node-server": "^1.19.10",
    "@tanstack/devtools-vite": "^0.5.2",
    "@tanstack/router-plugin": "^1.164.0",
    "@types/bun": "^1.3.10",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/browser": "^4.0.18",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "hono": "^4.12.5",
    "oxlint": "^1.51.0",
    "oxlint-tsgolint": "^0.16.0",
    "playwright": "^1.58.2",
    "rollup-plugin-bundle-stats": "^4.21.10",
    "tsr": "^1.3.4",
    "typescript": "^5.9.3",
    "vite": "8.0.0-beta.0",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "@shikijs/core": "^4.0.1",
    "@shikijs/engine-javascript": "^4.0.1",
    "@shikijs/engine-oniguruma": "^4.0.1",
    "@shikijs/langs": "^4.0.1",
    "@shikijs/themes": "^4.0.1",
    "@shikijs/transformers": "^4.0.1",
    "@shikijs/types": "^4.0.1",
    "shiki": "^4.0.1",
    "vite": "8.0.0-beta.0"
  }
}
